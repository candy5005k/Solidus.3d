DirectoryIndex index.html index.php
Options -Indexes

<IfModule mod_rewrite.c>
RewriteEngine On

RewriteRule ^includes/ - [F,L,NC]
RewriteRule ^config/ - [F,L,NC]

RewriteRule ^login\.html$ login.php [R=301,L,NC]
RewriteRule ^login/?$ login.php [L,QSA,NC]
RewriteRule ^forgot-password/?$ forgot-password.php [L,QSA,NC]
RewriteRule ^dashboard/?$ dashboard.php [L,QSA,NC]
RewriteRule ^profile/?$ profile.php [L,QSA,NC]
RewriteRule ^settings/?$ settings.php [L,QSA,NC]
RewriteRule ^about/?$ about.php [L,QSA,NC]
RewriteRule ^services/?$ services/index.html [L,QSA,NC]
RewriteRule ^portfolio/?$ portfolio.php [L,QSA,NC]
RewriteRule ^blog/?$ blog.php [L,QSA,NC]
RewriteRule ^contact/?$ contact.php [L,QSA,NC]
RewriteRule ^quote-dashboard/?$ quote-dashboard.php [L,QSA,NC]
RewriteRule ^logout/?$ logout.php [L,QSA,NC]
RewriteRule ^why-us/?$ why-us.php [L,QSA,NC]
RewriteRule ^process/?$ process.php [L,QSA,NC]
RewriteRule ^reviews/?$ reviews.php [L,QSA,NC]
RewriteRule ^faq/?$ faq.php [L,QSA,NC]
RewriteRule ^privacy/?$ privacy.php [L,QSA,NC]
RewriteRule ^terms/?$ terms.php [L,QSA,NC]
RewriteRule ^nda/?$ nda.php [L,QSA,NC]
RewriteRule ^blog/([A-Za-z0-9-]+)/?$ blog-post.php?slug=$1 [L,QSA,NC]
</IfModule>

<FilesMatch "^(README\.md|schema\.sql)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
</IfModule>
